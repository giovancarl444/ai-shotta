{
  "name": "ai-shotta",
  "version": "1.0.0",
  "description": "AI‑powered Solana token sniper ops system",
  "main": "app.js",
  "scripts": {
    "start": "concurrently \"node detectors/pumpDetector.js\" \"node snipeEngine.js\" \"node app.js\"",
    "watch": "node detector/index.js",
    "watch:quicknode": "node detector/quicknodeDetector.js",
    "watch:moralis": "node detector/moralisPoller.js",
    "migrate": "node scripts/manageQueue.js migrate",
    "cleanup": "node scripts/manageQueue.js cleanup",
    "simulate": "node scripts/runSimulation.js",
    "test": "jest"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@solana/spl-token-registry": "^0.2.0",
    "@solana/web3.js": "^1.98.0",
    "ansi-colors": "^4.1.1",
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "openai": "^4.93.0",
    "papaparse": "^5.5.2",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.15",
    "concurrently": "^9.1.2",
    "jest": "^29.0.0"
  }
}
