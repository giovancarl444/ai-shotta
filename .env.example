# .env.example
# Copy this to `.env` and fill in your real keys

# RPC endpoint for Solana (Devnet for testing / Mainnet via GenesysGo)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Pump.fun and Moralis
MORALIS_API_KEY=your_moralis_api_key
# (If you re‑enable streams) MORALIS_STREAM_URL=https://api.moralis.io/streams/your_stream_id/events

# BirdEye (optional metadata backup)
BIRDEYE_API_KEY=your_birdeye_key
BIRDEYE_METADATA_KEY=your_birdeye_metadata_key

# Engine timings & retry caps
PROCESS_INTERVAL_MS=5000
ENRICH_MAX_RETRIES=3

# Live execution flag
LIVE_MODE=false
